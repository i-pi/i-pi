<simulation verbosity='medium'>
  <!-- Two independent MPI driver forcefields in a single MPMD job. Each ffmpi
       is served by the driver ranks launched with the matching mpi-name flag
       (see run.sh). Here both are harmonic (k=1 and k=2) so the total force is
       proportional to (1+2)*x, but the two drivers could run different codes. -->
  <output prefix='simulation'>
    <properties stride='2' filename='out'> [ step, time{picosecond}, conserved{kelvin}, temperature{kelvin}, potential{kelvin} ] </properties>
    <trajectory filename='pos' stride='4' format='xyz' cell_units='angstrom'> positions{angstrom} </trajectory>
  </output>
  <total_steps>400</total_steps>
  <prng><seed>3348</seed></prng>
  <ffmpi name='ffA' mode='mpi'><batch_size>4</batch_size></ffmpi>
  <ffmpi name='ffB' mode='mpi'></ffmpi>
  <system>
    <initialize nbeads='4'>
      <cell mode='abc'> [ 15.0, 15.0, 15.0 ] </cell>
      <file mode='xyz'> init.xyz </file>
      <velocities mode='thermal' units='kelvin'> 3683.412077 </velocities>
    </initialize>
    <forces>
      <force forcefield='ffA'/>
      <force forcefield='ffB'/>
    </forces>
    <ensemble> <temperature units='kelvin'> 3683.412077 </temperature> </ensemble>
    <motion mode='dynamics'>
      <dynamics mode='nvt'>
        <thermostat mode='langevin'> <tau units='femtosecond'> 25 </tau> </thermostat>
        <timestep units='femtosecond'> 0.003 </timestep>
      </dynamics>
    </motion>
  </system>
</simulation>
