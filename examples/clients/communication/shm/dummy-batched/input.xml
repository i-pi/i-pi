<simulation verbosity='high'>
  <output prefix='simulation'>
    <properties stride='5' filename='out'>  [ step, time{picosecond}, conserved{kelvin}, temperature{kelvin}, kinetic_cv{kelvin}, potential{kelvin} ] </properties>
    <trajectory filename='pos' stride='5' format='xyz' cell_units='angstrom'> positions{angstrom} </trajectory>
  </output>
  <total_steps>100</total_steps>
  <prng>
    <seed>3348</seed>
  </prng>
  <!-- The "gas" PES is a vectorized no-op (ideal gas): zero potential, force
       and virial. With batch_size it evaluates the whole batch in a single
       (trivial) call, which makes it a clean target to measure the communication
       / dispatch cost of the batched socket path. The same `i-pi-py_driver`
       command runs batched or not; batching is requested from the input. -->
  <ffsocket mode='shm' name='driver'>
    <address>localhost</address>
    <batch_size>4</batch_size>
  </ffsocket>
  <system>
    <initialize nbeads='4'>
      <cell mode='abc'>
        [   15., 15.0, 15.0 ]
      </cell>
      <file mode='xyz'> init.xyz </file>
      <velocities mode='thermal' units='kelvin'>3683.412077</velocities>
    </initialize>
    <forces>
      <force forcefield='driver'/>
    </forces>
    <ensemble>
      <temperature units='kelvin'>3683.412077</temperature>
    </ensemble>
    <motion mode='dynamics'>
      <dynamics mode='nvt'>
        <thermostat mode='langevin'>
          <tau units='femtosecond'>25</tau>
        </thermostat>
        <timestep units='femtosecond'>0.003</timestep>
      </dynamics>
    </motion>
  </system>
</simulation>
