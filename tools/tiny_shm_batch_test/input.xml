<simulation verbosity='low' threading='false' safe_stride='10'>
  <ffsocket mode='shm' name='mydriver' pbc='false' batch='true' matching='lock'>
    <latency>1.0e-4</latency>
    <address>mydriver</address>
    <exit_on_disconnect>false</exit_on_disconnect>
  </ffsocket>

  <total_steps>5</total_steps>

  <output prefix='simulation'>
    <properties stride='1'>[ step, time, conserved, temperature, kinetic_md, potential ]</properties>
    <trajectory stride='5' filename='pos'> positions </trajectory>
  </output>

  <prng>
    <seed>18885</seed>
  </prng>

  <system>
    <forces>
      <force forcefield='mydriver' weight='1'></force>
    </forces>

    <initialize nbeads='2'>
      <file mode='xyz'>init.xyz</file>
      <cell>[10.0, 0, 0, 0, 10.0, 0, 0, 0, 10.0]</cell>
      <masses mode='manual'>[1.0, 1.0]</masses>
      <velocities mode='thermal'>1</velocities>
    </initialize>

    <ensemble>
      <temperature>1</temperature>
    </ensemble>

    <motion mode='dynamics'>
      <fixcom>false</fixcom>
      <dynamics mode='nvt'>
        <timestep>0.1</timestep>
        <thermostat mode='langevin'>
          <tau>1</tau>
        </thermostat>
      </dynamics>
    </motion>
  </system>
</simulation>
